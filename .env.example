# =============================================================
# .env.example — 실제 사용 시 .env 로 복사하여 값을 교체하세요
# cp .env.example .env
# =============================================================

# ── Database (PostgreSQL) ──────────────────────────────────────
DB_USER=travel
DB_PASSWORD=P@ssw0rd$
DB_PORT=5432
DB_HOST=localhost

# ── Cache (Redis) ──────────────────────────────────────────────
REDIS_PORT=6379
REDIS_HOST=localhost

# ── Prism Mock 포트 (mock 프로파일) ───────────────────────────
MOCK_PORT_AUTH=4010
MOCK_PORT_SCHEDULE=4011
MOCK_PORT_PLACE=4012
MOCK_PORT_MONITOR=4013
MOCK_PORT_BRIEFING=4014
MOCK_PORT_ALTERNATIVE=4015
MOCK_PORT_PAYMENT=4016
MOCK_PORT_AI_PIPELINE=4017

# ── JWT ────────────────────────────────────────────────────────
JWT_SECRET=your-very-long-secret-key-here-must-be-at-least-256-bits

# ── External APIs (실제 값으로 교체 필요) ─────────────────────
GOOGLE_PLACES_API_KEY=your-google-places-api-key
OPENWEATHERMAP_API_KEY=your-openweathermap-api-key
FCM_SERVER_KEY=your-fcm-server-key

# ── Google OAuth ───────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Apple Sign In ──────────────────────────────────────────────
APPLE_CLIENT_ID=your-apple-client-id
APPLE_TEAM_ID=your-apple-team-id
APPLE_KEY_ID=your-apple-key-id

# ── CORS ───────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000
