@startuml
!theme mono

title PLACE 서비스 - Entity Relationship Diagram

!define TABLE(name,desc) class name as "desc" << (T,#FFAAAA) >>
!define PK(x) <b>x</b>
!define FK(x) <i>x</i>
!define UNIQUE(x) <u>x</u>

TABLE(places, "PLACES\n(장소)") {
    PK(id: VARCHAR(200))
    --
    name: VARCHAR(200) NOT NULL
    address: VARCHAR(500)
    category: VARCHAR(50)
    rating: NUMERIC(3,1)
    lat: NUMERIC(10,7) NOT NULL
    lng: NUMERIC(10,7) NOT NULL
    timezone: VARCHAR(50)
    photo_url: VARCHAR(500)
    city: VARCHAR(100)
    --
    updated_at: TIMESTAMPTZ NOT NULL
}

TABLE(place_business_hours, "PLACE_BUSINESS_HOURS\n(영업시간)") {
    PK(id: SERIAL)
    --
    FK(place_id: VARCHAR(200)) NOT NULL
    day_of_week: VARCHAR(10) NOT NULL
    open_time: VARCHAR(5)
    close_time: VARCHAR(5)
}

' 관계 정의
places ||--o{ place_business_hours : "has business hours"

note top of places
  <b>Indexes:</b>
  • idx_places_city (city)
  • idx_places_category (category)
  • idx_places_city_category (city, category)
  • idx_places_coordinates (lat, lng)
  • idx_places_updated_at (updated_at)

  <b>Check Constraints:</b>
  • rating BETWEEN 0.0 AND 5.0

  <b>Design Note:</b>
  • PK = Google Place ID (외부 시스템 키)
  • Upsert 방식으로 갱신
  • PostgreSQL은 Google API 영속 캐시 역할
end note

note bottom of place_business_hours
  <b>Indexes:</b>
  • idx_place_business_hours_place_id (place_id)

  <b>Foreign Key Actions:</b>
  • place_id: ON DELETE CASCADE

  <b>Check Constraints:</b>
  • day_of_week IN ('MONDAY','TUESDAY',
    'WEDNESDAY','THURSDAY','FRIDAY',
    'SATURDAY','SUNDAY')
end note

legend right
  <b>Redis Cache (DB 3):</b>
  plce:detail:{placeId}              TTL 1시간
  plce:search:{keyword}:{city}       TTL 30분
  plce:nearby:{latLng}:{cat}:{rad}   TTL 15분

  <b>External Source:</b>
  Google Places API (textSearch,
  nearbySearch, placeDetail)

  <b>Legend:</b>
  PK = Primary Key
  FK = Foreign Key
end legend

@enduml
