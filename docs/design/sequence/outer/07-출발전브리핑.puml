@startuml
!theme mono

title 출발 전 브리핑 생성 및 수신 (BRIF, MNTR) [S04]

actor "스케줄러" as scheduler
actor "여행자" as user
participant "모바일 클라이언트" as fe
participant "API Gateway" as gw
participant "BRIF 서비스" as brif
participant "MNTR 서비스" as mntr
database "Redis 캐시(E)" as cache
participant "FCM(E)" as fcm

== 출발 전 브리핑 트리거 (15~30분 전) ==
scheduler -> brif : 브리핑 생성 트리거 (출발 15~30분 전)
activate brif

brif -> brif : 멱등성 키 확인\n(place_id + departure_time 해시)

alt 이미 생성된 브리핑 존재 (P21)
    brif --> scheduler : 기존 브리핑 ID 반환 (중복 방지)
else 신규 브리핑 생성
    brif -> mntr : 최신 수집 데이터 조회 (캐시 Read-Through)
    activate mntr
    mntr -> cache : 캐시 조회 (5분 이내 데이터)
    activate cache
    alt 캐시 데이터 5분 이내
        cache --> mntr : 캐시 데이터 반환
        deactivate cache
        mntr --> brif : 영업상태, 날씨, 혼잡도, 이동시간
    else 캐시 데이터 5분 초과
        cache --> mntr : 캐시 만료
        deactivate cache
        mntr ->> mntr : 비동기 데이터 수집 후 반환
        mntr --> brif : 최신 수집 데이터
    end
    deactivate mntr

    brif -> brif : 구독 티어 확인\n(Free: 1일 1회 한도)

    alt Free 티어 한도 초과 (P19)
        brif --> scheduler : FREE_TIER_LIMIT_EXCEEDED (스킵)
    else 한도 이내 또는 유료 티어
        brif -> brif : 안심/주의 분기 판단\n+ 총평 생성 (RuleBasedGenerator)

        brif ->> fcm : Push 알림 발송 요청 (비동기, Circuit Breaker)
        activate fcm

        alt FCM Circuit Breaker CLOSED
            fcm -->> brif : 발송 완료
            deactivate fcm

            fcm ->> fe : Push 알림 전송\n(안심: "다음 목적지 준비 완료"\n 주의: "다음 목적지 확인 필요")

            user -> fe : Push 알림 탭
            fe -> gw : GET /api/v1/briefings/{briefing_id}
            activate gw
            gw -> brif : 브리핑 상세 조회
            brif --> gw : 영업상태, 혼잡도, 날씨, 이동시간, 총평
            gw --> fe : 브리핑 상세
            deactivate gw
            fe --> user : 브리핑 상세 화면 표시

        else FCM Circuit Breaker OPEN (Fallback)
            fcm -->> brif : 발송 실패
            deactivate fcm
            brif ->> fe : 인앱 알림 Fallback
        end
    end
end

deactivate brif

@enduml
