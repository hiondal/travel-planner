@startuml
!theme mono

title 소셜 로그인 (AUTH)

actor "여행자" as user
participant "모바일 클라이언트" as fe
participant "API Gateway" as gw
participant "AUTH 서비스" as auth
database "Redis 캐시(E)" as cache
participant "Google/Apple OAuth(E)" as oauth

== Google/Apple 로그인 요청 ==
user -> fe : Google 또는 Apple 로그인 버튼 탭
fe -> oauth : OAuth 인증 화면 표시 요청
activate oauth
oauth --> fe : OAuth 인증 화면 반환
deactivate oauth

user -> fe : Google/Apple 계정 인증 완료
fe -> gw : POST /api/v1/auth/social-login\n{provider, oauth_code}
activate gw

gw -> auth : 소셜 로그인 요청 전달
activate auth

auth ->> oauth : OAuth 토큰 검증 요청 (비동기)
activate oauth

alt OAuth 검증 성공
    oauth -->> auth : 사용자 프로필 반환 (비동기)
    deactivate oauth

    auth -> cache : 세션 정보 저장\n(user_id, refresh_token, TTL 30분)
    activate cache
    cache --> auth : 저장 완료
    deactivate cache

    auth --> gw : 200 OK\n{access_token(30분), refresh_token, user_profile}
    gw --> fe : 로그인 성공 응답
    fe --> user : 메인 화면 이동 (온보딩 여부 판단)

else OAuth 검증 실패
    oauth -->> auth : 인증 실패 반환 (비동기)
    deactivate oauth
    auth --> gw : 401 Unauthorized
    gw --> fe : 로그인 실패 응답
    fe --> user : "로그인에 실패했습니다. 다시 시도해주세요" 표시

else 네트워크 오류
    auth --> gw : 503 Service Unavailable
    gw --> fe : 오류 응답
    fe --> user : "인터넷 연결을 확인해주세요" 표시
end

deactivate auth
deactivate gw

@enduml
