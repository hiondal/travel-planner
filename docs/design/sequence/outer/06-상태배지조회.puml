@startuml
!theme mono

title 상태 배지 조회 (MNTR) [S05]

actor "여행자" as user
participant "모바일 클라이언트" as fe
participant "API Gateway" as gw
participant "MNTR 서비스" as mntr
database "Redis 캐시(E)" as cache

== 상태 배지 목록 조회 ==
user -> fe : 일정표 배지 새로고침 또는 화면 진입
fe -> gw : GET /api/v1/badges?place_ids={ids}
activate gw
gw -> mntr : 배지 상태 목록 조회
activate mntr

mntr -> cache : 배지 캐시 일괄 조회\n(mntr:{place_id}:badge)
activate cache

alt 캐시 HIT (TTL 10분 이내)
    cache --> mntr : 배지 상태 목록 반환
    deactivate cache
    mntr --> gw : 초록+체크/노랑+느낌표/빨강+X/회색+물음표

else 캐시 MISS
    cache --> mntr : 캐시 없음
    deactivate cache
    mntr -> mntr : DB에서 최신 상태 조회
    mntr -> cache : 캐시 갱신 (TTL 10분)
    mntr --> gw : 배지 상태 목록 반환
end

deactivate mntr
gw --> fe : 배지 상태 응답
deactivate gw
fe --> user : 장소별 상태 배지 표시\n(색상 + 아이콘 조합, 색약 지원)

== 상태 상세 조회 ==
user -> fe : 배지 탭 (노랑 또는 빨강)
fe -> gw : GET /api/v1/badges/{place_id}/detail
activate gw
gw -> mntr : 배지 상세 조회
activate mntr
mntr --> gw : 영업상태, 혼잡도, 날씨,\n이동시간(도보/대중교통), 판정사유
deactivate mntr
gw --> fe : 상세 정보 응답
deactivate gw

fe --> user : 상태 상세 팝업\n(노랑/빨강 시 "대안 보기" 버튼 포함)

@enduml
