@startuml
!theme mono

title 일정표 조회 - 상태 배지 포함 (SCHD, MNTR) [S05]

actor "여행자" as user
participant "모바일 클라이언트" as fe
participant "API Gateway" as gw
participant "SCHD 서비스" as schd
participant "MNTR 서비스" as mntr
database "Redis 캐시(E)" as cache

== 일정표 조회 ==
user -> fe : 일정표 화면 진입
fe -> gw : GET /api/v1/trips/{trip_id}/schedule
activate gw
gw -> schd : 일정표 조회 요청
activate schd
schd --> gw : 일정 장소 목록 반환 (place_id 목록 포함)
deactivate schd

== 상태 배지 일괄 조회 ==
gw -> mntr : GET /api/v1/badges?place_ids={ids}
activate mntr

mntr -> cache : 배지 상태 캐시 조회 (mntr:{place_id}:badge)
activate cache

alt 캐시 HIT (TTL 10분 이내)
    cache --> mntr : 배지 상태 반환
    deactivate cache
    mntr --> gw : 장소별 배지 상태 목록\n(초록/노랑/빨강/회색 + 아이콘)

else 캐시 MISS
    cache --> mntr : 캐시 없음
    deactivate cache
    mntr -> mntr : DB 직접 조회 후 캐시 갱신
    mntr --> gw : 장소별 배지 상태 목록
end

deactivate mntr

gw --> fe : 일정표 + 배지 상태 통합 응답
deactivate gw

fe --> user : 일정표 표시\n(장소명 + 시간 + 상태 배지)

== 배지 탭 - 상태 상세 조회 ==
user -> fe : 노랑/빨강 배지 탭
fe -> gw : GET /api/v1/badges/{place_id}/detail
activate gw
gw -> mntr : 배지 상세 정보 조회
activate mntr
mntr --> gw : 영업상태, 날씨, 혼잡도, 이동시간, 판정사유
deactivate mntr
gw --> fe : 배지 상세 응답
deactivate gw
fe --> user : 상태 상세 팝업 표시\n("대안 보기" 버튼 포함)

@enduml
