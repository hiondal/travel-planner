@startuml
!theme mono

title 여행 일정 등록 (SCHD, PLCE)

actor "여행자" as user
participant "모바일 클라이언트" as fe
participant "API Gateway" as gw
participant "SCHD 서비스" as schd
participant "PLCE 서비스" as plce
participant "이벤트 버스" as bus
participant "MNTR 서비스" as mntr

== 여행 일정 생성 ==
user -> fe : 여행명, 기간, 도시 입력 후 생성 버튼 탭
fe -> gw : POST /api/v1/trips\n{name, start_date, end_date, city}
activate gw
gw -> schd : 여행 일정 생성 요청
activate schd

alt 첫 번째 여행 일정 생성 (권한 동의)
    schd --> gw : 위치정보 동의 요청 필요 응답
    gw --> fe : 동의 화면 표시 요청
    user -> fe : 위치정보 수집 동의
    fe -> gw : POST /api/v1/users/consent\n{location: true, push: true, timestamp}
    gw -> schd : 동의 이력 저장
end

schd --> gw : 201 Created\n{trip_id, empty_schedule}
deactivate schd
gw --> fe : 일정 생성 완료
deactivate gw
fe --> user : 빈 일정표 화면 이동

== 장소 검색 ==
user -> fe : 장소 추가 버튼 탭 → 검색어 입력
fe -> gw : GET /api/v1/places/search?keyword={검색어}&city={도시}
activate gw
gw -> schd : 장소 검색 중개 요청
activate schd
schd -> plce : 키워드 기반 장소 검색
activate plce
plce --> schd : 장소 목록 반환 (최대 10개)
deactivate plce
schd --> gw : 장소 검색 결과
deactivate schd
gw --> fe : 장소 목록 응답
deactivate gw
fe --> user : 장소 목록 표시 (이름, 주소, 평점)

== 일정에 장소 추가 ==
user -> fe : 장소 선택 후 방문 일시 지정
fe -> gw : POST /api/v1/trips/{trip_id}/schedule-items\n{place_id, visit_datetime(IANA timezone)}
activate gw
gw -> schd : 일정에 장소 추가 요청
activate schd

alt 영업시간 내 방문 시간
    schd ->> bus : ScheduleItemAdded 이벤트 발행 (비동기)
    bus -->  mntr : 모니터링 대상 등록
    schd --> gw : 201 Created\n{schedule_item_id}
    gw --> fe : 장소 추가 완료
    fe --> user : 일정표에 장소 표시 (시간순 정렬)

else 영업시간 외 방문 시간
    schd --> gw : 200 OK with warning\n{warning: "영업시간 외 (11:00~22:00)"}
    gw --> fe : 경고 포함 응답
    fe --> user : 경고 메시지 표시 및 추가 여부 확인
    user -> fe : 경고 무시하고 추가 확인
    fe -> gw : POST /api/v1/trips/{trip_id}/schedule-items\n{force: true}
    gw -> schd : 강제 추가 요청
    schd ->> bus : ScheduleItemAdded 이벤트 발행 (비동기)
    bus --> mntr : 모니터링 대상 등록 (영업시간 외 마킹)
    schd --> gw : 201 Created
    gw --> fe : 장소 추가 완료
    fe --> user : 일정표에 장소 표시
end

deactivate schd
deactivate gw

@enduml
