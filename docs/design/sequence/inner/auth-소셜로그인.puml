@startuml
!theme mono

title AUTH 서비스 - 소셜 로그인

participant "AuthController" as ctrl
participant "AuthService" as svc
participant "UserRepository" as repo
database "PostgreSQL(E)" as db
database "Redis Cache(E)" as cache
participant "Google/Apple OAuth(E)" as oauth

-> ctrl : POST /api/v1/auth/social-login\n{provider, oauth_code}
activate ctrl

ctrl -> svc : socialLogin(provider, oauth_code)
activate svc

svc ->> oauth : OAuth 토큰 검증 요청 (비동기)
activate oauth

alt OAuth 검증 성공
    oauth -->> svc : 사용자 프로필 반환\n{provider_id, email, name, avatar_url}
    deactivate oauth

    svc -> repo : 사용자 조회 (provider_id 기준)
    activate repo
    repo -> db : users 테이블 조회
    db --> repo : 조회 결과
    deactivate repo

    alt 신규 사용자 (최초 로그인)
        svc -> repo : 사용자 생성
        activate repo
        repo -> db : users 테이블 삽입\n(provider, provider_id, email, nickname, avatar_url)
        db --> repo : 생성된 user_id
        deactivate repo
        note right of svc : 닉네임/프로필 이미지 자동 설정
    end

    svc -> svc : JWT Access Token 생성 (30분)\n+ Refresh Token 생성
    note right of svc : JWT 클레임:\nuser_id, tier, email, exp

    svc -> repo : auth_sessions 저장
    activate repo
    repo -> db : auth_sessions 테이블 삽입\n(user_id, refresh_token, expires_at)
    db --> repo : 저장 완료
    deactivate repo

    svc -> cache : 세션 정보 저장\n(sess:{user_id}:token, TTL 30분)
    activate cache
    cache --> svc : 저장 완료
    deactivate cache

    svc --> ctrl : {access_token, refresh_token, user_profile}

else OAuth 검증 실패
    oauth -->> svc : 인증 실패
    deactivate oauth
    svc --> ctrl : AuthException (인증 실패)
end

deactivate svc

alt 성공
    ctrl --> : 200 OK\n{access_token, refresh_token, user_profile}
else 실패
    ctrl --> : 401 Unauthorized
end
deactivate ctrl

@enduml
