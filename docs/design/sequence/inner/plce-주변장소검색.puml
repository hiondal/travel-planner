@startuml
!theme mono

title PLCE 서비스 - 주변 장소 검색 (반경 기반)

participant "PlceController" as ctrl
participant "PlaceService" as svc
participant "PlaceRepository" as repo
database "PostgreSQL(E)" as db
database "Redis Cache(E)" as cache
participant "Google Places API(E)" as gplaces

-> ctrl : GET /api/v1/places/nearby\n?lat={위도}&lng={경도}&category={카테고리}&radius={반경}
activate ctrl

ctrl -> ctrl : 요청 검증 (좌표 유효성, 카테고리, 반경 1/2/3km)

ctrl -> svc : searchNearbyPlaces(lat, lng, category, radius)
activate svc

svc -> cache : 캐시 조회\n(place:nearby:{lat}:{lng}:{category}:{radius})
activate cache

alt 캐시 HIT
    cache --> svc : 주변 장소 목록 반환
    deactivate cache
    svc --> ctrl : 장소 목록 (거리, 평점, 좌표 포함)

else 캐시 MISS
    cache --> svc : 캐시 없음
    deactivate cache

    svc -> gplaces : Google Places Nearby Search API 호출\n(Circuit Breaker + Retry)\n{location, radius, type=category, open_now=true}
    activate gplaces

    alt API 정상 응답
        gplaces --> svc : 주변 장소 목록 반환\n(영업 중, 동일 카테고리 필터)
        deactivate gplaces

        svc -> svc : 거리 계산 (원점 기준 도보 이동거리)
        svc -> svc : 결과 정렬 (거리 기준)

        svc -> repo : 장소 데이터 저장/갱신
        activate repo
        repo -> db : places 테이블 Upsert
        db --> repo : 저장 완료
        deactivate repo

        svc -> cache : 검색 결과 캐시 저장 (TTL 5분)
        activate cache
        cache --> svc : 저장 완료
        deactivate cache

        svc --> ctrl : 장소 목록 (거리, 평점, 좌표 포함)

    else API 실패
        gplaces --> svc : API 오류
        deactivate gplaces
        svc --> ctrl : 503 Service Unavailable
    end
end

deactivate svc
ctrl --> : 200 OK\n{places: [{id, name, distance_m, rating, coords, category}]}
deactivate ctrl

@enduml
