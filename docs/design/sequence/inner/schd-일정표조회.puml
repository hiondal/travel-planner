@startuml
!theme mono

title SCHD 서비스 - 일정표 조회

participant "SchdController" as ctrl
participant "TripService" as svc
participant "TripRepository" as repo
participant "ScheduleItemRepository" as srepo
participant "MntrService(E)" as mntr
database "PostgreSQL(E)" as db
database "Redis Cache(E)" as cache

-> ctrl : GET /api/v1/trips/{trip_id}/schedule
activate ctrl

ctrl -> ctrl : trip_id 소유권 검증 (JWT user_id)

ctrl -> svc : getSchedule(trip_id, user_id)
activate svc

svc -> repo : 여행 일정 조회
activate repo
repo -> db : trips 테이블 조회 (trip_id, user_id)
db --> repo : 여행 정보
deactivate repo

svc -> srepo : 일정 장소 목록 조회 (시간순)
activate srepo
srepo -> db : schedule_items 조회 (trip_id, ORDER BY visit_datetime)
db --> srepo : 장소 목록 (place_id 목록 포함)
deactivate srepo

== 상태 배지 일괄 조회 ==
svc -> mntr : 배지 상태 일괄 조회 (place_id 목록)
activate mntr

mntr -> cache : 배지 캐시 일괄 조회
activate cache
alt 캐시 HIT
    cache --> mntr : 배지 상태 목록
    deactivate cache
else 캐시 MISS
    cache --> mntr : 캐시 없음
    deactivate cache
    mntr -> mntr : DB 조회 후 캐시 갱신
end
mntr --> svc : 장소별 배지 상태 반환
deactivate mntr

svc -> svc : 일정표 + 배지 상태 통합

svc --> ctrl : {trip_info, schedule_items [{place, visit_datetime, badge_status}]}
deactivate svc

ctrl --> : 200 OK\n{일정표 + 배지 포함}
deactivate ctrl

@enduml
