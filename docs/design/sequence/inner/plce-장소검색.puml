@startuml
!theme mono

title PLCE 서비스 - 장소 검색

participant "PlceController" as ctrl
participant "PlaceService" as svc
participant "PlaceRepository" as repo
database "PostgreSQL(E)" as db
database "Redis Cache(E)" as cache
participant "Google Places API(E)" as gplaces

-> ctrl : GET /api/v1/places/search?keyword={키워드}&city={도시}
activate ctrl

ctrl -> ctrl : 요청 검증 (키워드 2자 이상, 도시 지원 여부)

ctrl -> svc : searchPlaces(keyword, city)
activate svc

svc -> cache : 캐시 조회 (place:search:{keyword}:{city})
activate cache

alt 캐시 HIT
    cache --> svc : 장소 목록 반환
    deactivate cache
    svc --> ctrl : 장소 목록 (최대 10개)

else 캐시 MISS
    cache --> svc : 캐시 없음
    deactivate cache

    svc -> gplaces : Google Places Text Search API 호출\n(Circuit Breaker + Retry)
    activate gplaces

    alt API 정상 응답
        gplaces --> svc : 장소 목록 (이름, 주소, 좌표, 평점, 영업시간)
        deactivate gplaces

        svc -> repo : 장소 데이터 저장/갱신 (Upsert)
        activate repo
        repo -> db : places 테이블 Upsert
        db --> repo : 저장 완료
        deactivate repo

        svc -> cache : 검색 결과 캐시 저장 (TTL 5분)
        activate cache
        cache --> svc : 저장 완료
        deactivate cache

        svc --> ctrl : 장소 목록 (최대 10개)

    else API 실패 (Circuit Breaker OPEN)
        gplaces --> svc : API 오류
        deactivate gplaces
        svc -> repo : DB에서 도시 내 장소 검색 (Fallback)
        activate repo
        repo -> db : places 조회 (keyword LIKE, city 필터)
        db --> repo : 장소 목록
        deactivate repo
        svc --> ctrl : 장소 목록 (DB Fallback)
    end
end

deactivate svc
ctrl --> : 200 OK\n{places: [{id, name, address, rating, business_hours}]}
deactivate ctrl

@enduml
