@startuml
!theme mono

title ALTN 서비스 - 대안 장소 검색

participant "AltnController" as ctrl
participant "AlternativeService" as svc
participant "AlternativeRepository" as repo
participant "PlceService(E)" as plce
participant "MntrService(E)" as mntr
database "PostgreSQL(E)" as db
database "Redis Cache(E)" as cache

-> ctrl : POST /api/v1/alternatives/search\n{place_id, category, lat, lng}
activate ctrl

ctrl -> ctrl : JWT 클레임에서 구독 티어 확인
alt Free 티어
    ctrl --> : 402 Payment Required\n{paywall: true}
else 유료 티어

    ctrl -> svc : searchAlternatives(place_id, category, location)
    activate svc

    == 대안 카드 캐시 확인 ==
    svc -> cache : 캐시 조회 (altn:{place_id}:{category}:{radius})
    activate cache
    alt 캐시 HIT (TTL 5분)
        cache --> svc : 대안 카드 목록 반환
        deactivate cache
    else 캐시 MISS
        cache --> svc : 캐시 없음
        deactivate cache

        == 주변 장소 검색 (단계적 반경 확장) ==
        svc -> plce : 반경 1km 주변 장소 검색 (동일 카테고리, 영업 중)
        activate plce
        plce --> svc : 장소 목록 반환
        deactivate plce

        alt 결과 3장 미만 (P22)
            svc -> plce : 반경 2km 추가 검색 (1km~2km 구간)
            activate plce
            plce --> svc : 추가 장소 목록 (누적)
            deactivate plce

            alt 여전히 3장 미만
                svc -> plce : 반경 3km 추가 검색 (2km~3km 구간)
                activate plce
                plce --> svc : 추가 장소 목록 (누적)
                deactivate plce
            end
        end

        == 배지 상태 필터링 ==
        svc -> mntr : 후보 장소 배지 상태 일괄 조회
        activate mntr
        mntr --> svc : 장소별 배지 상태
        deactivate mntr

        svc -> svc : 빨강 상태 장소 제외
        note right of svc
            초록: 최우선
            노랑: "주의 필요" 레이블
            회색: "정보 미확인" 레이블 (최후보)
            빨강: 제외
        end note

        == 합산 점수 정렬 및 상위 3장 선택 ==
        svc -> svc : score = 0.5*distance + 0.3*rating + 0.2*congestion\n상위 3장 선택

        == 대안 카드 캐시 저장 ==
        svc -> cache : 대안 카드 캐시 저장 (TTL 5분)
        activate cache
        cache --> svc : 저장 완료
        deactivate cache
    end

    svc -> repo : 대안 카드 노출 이벤트 저장 (분석 데이터)
    activate repo
    repo -> db : alternative_cards 삽입\n(cards 스냅샷: 거리, 평점, 혼잡도)
    db --> repo : 저장 완료
    deactivate repo

    svc --> ctrl : {cards: [{place_id, name, distance_m, rating, congestion, reason, status_label}]}
    deactivate svc

    ctrl --> : 200 OK\n{대안 카드 최대 3장}
end

deactivate ctrl

@enduml
