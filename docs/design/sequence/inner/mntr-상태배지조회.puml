@startuml
!theme mono

title MNTR 서비스 - 상태 배지 조회

participant "MntrController" as ctrl
participant "BadgeService" as svc
participant "StatusRepository" as repo
database "PostgreSQL(E)" as db
database "Redis Cache(E)" as cache

-> ctrl : GET /api/v1/badges?place_ids={ids}
activate ctrl

ctrl -> svc : getBadgeStatuses(place_ids)
activate svc

loop 각 place_id (배치 처리)
    svc -> cache : 배지 캐시 조회 (mntr:{place_id}:badge)
    activate cache

    alt 캐시 HIT (TTL 10분 이내)
        cache --> svc : {status, icon, label}
        deactivate cache

    else 캐시 MISS
        cache --> svc : 캐시 없음
        deactivate cache

        svc -> repo : 현재 상태 DB 조회
        activate repo
        repo -> db : status_current 조회 (place_id)
        db --> repo : {status, updated_at, reason}
        deactivate repo

        svc -> cache : 배지 캐시 저장 (TTL 10분)
        activate cache
        cache --> svc : 저장 완료
        deactivate cache
    end

    svc -> svc : 배지 표현 매핑
    note right of svc
        초록 -> 초록+체크 아이콘
        노랑 -> 노랑+느낌표 아이콘
        빨강 -> 빨강+X 아이콘
        회색 -> 회색+물음표 + "데이터 미확인"
    end note
end

svc --> ctrl : [{place_id, status, icon, label, updated_at}]
deactivate svc

ctrl --> : 200 OK\n{badges: [...]}
deactivate ctrl

@enduml
