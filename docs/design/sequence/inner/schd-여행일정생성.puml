@startuml
!theme mono

title SCHD 서비스 - 여행 일정 생성

participant "SchdController" as ctrl
participant "TripService" as svc
participant "TripRepository" as repo
participant "ConsentRepository" as crepo
database "PostgreSQL(E)" as db

-> ctrl : POST /api/v1/trips\n{name, start_date, end_date, city}
activate ctrl

ctrl -> ctrl : 요청 데이터 검증\n(여행명 1~50자, 기간 유효성, 도시 지원 여부)

ctrl -> svc : createTrip(user_id, request)
activate svc

svc -> crepo : 위치정보 동의 이력 조회
activate crepo
crepo -> db : consent_records 조회 (user_id)
db --> crepo : 동의 이력
deactivate crepo

alt 첫 번째 여행 (동의 이력 없음)
    svc --> ctrl : ConsentRequiredException
    ctrl --> : 428 Precondition Required\n{consent_required: true}
    note right of ctrl : 클라이언트가 동의 처리 후 재요청
else 동의 완료
    svc -> repo : 여행 일정 생성
    activate repo
    repo -> db : trips 테이블 삽입\n(user_id, name, start_date, end_date, city, status=ACTIVE)
    db --> repo : 생성된 trip_id
    deactivate repo

    svc --> ctrl : {trip_id, name, start_date, end_date, city, schedule_items: []}
end

deactivate svc

ctrl --> : 201 Created\n{trip_id, empty_schedule}
deactivate ctrl

@enduml
