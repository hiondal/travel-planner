@startuml
!theme mono

title ALTN 서비스 - 대안 카드 선택 및 일정 반영

participant "AltnController" as ctrl
participant "AlternativeService" as svc
participant "AlternativeRepository" as repo
participant "SchdService(E)" as schd
database "PostgreSQL(E)" as db
database "Redis Cache(E)" as cache

-> ctrl : POST /api/v1/alternatives/{alt_id}/select\n{original_place_id, schedule_item_id, trip_id}
activate ctrl

ctrl -> svc : selectAlternative(alt_id, original_place_id, schedule_item_id)
activate svc

svc -> repo : 선택된 대안 카드 정보 조회
activate repo
repo -> db : alternative_cards 조회 (alt_id)
db --> repo : 대안 장소 정보
deactivate repo

== SCHD 서비스 동기 호출로 일정 교체 ==
svc -> schd : 일정 교체 요청\n(schedule_item_id, new_place_id)
activate schd
schd --> svc : 일정 교체 완료\n{변경 요약: 원래→대안, 이동시간 변화}
deactivate schd

== 캐시 무효화 ==
svc -> cache : 기존 장소 대안 카드 캐시 무효화\n(altn:{original_place_id}:*)
activate cache
cache --> svc : 무효화 완료
deactivate cache

== 선택 이력 저장 (ML 학습 데이터) ==
svc -> repo : 대안 카드 선택 이력 저장
activate repo
repo -> db : selection_logs 삽입\n(alt_card_id, selected_rank(1/2/3),\nelapsed_seconds, adopted=true)
db --> repo : 저장 완료
deactivate repo

svc --> ctrl : {변경 요약}
deactivate svc

ctrl --> : 200 OK\n{original_place, new_place, travel_time_diff}
deactivate ctrl

@enduml
