@startuml
!theme mono

title MNTR 서비스 - 외부 데이터 수집 (스케줄러 주도)

participant "DataCollectionScheduler" as scheduler
participant "MonitoringService" as svc
participant "MonitoringRepository" as repo
database "PostgreSQL(E)" as db
database "Redis Cache(E)" as cache
participant "Azure App Config(E)" as config
participant "Google Places API(E)" as gplaces
participant "OpenWeatherMap API(E)" as weather
participant "Google Directions API(E)" as gdirections
participant "EventBus(E)" as bus

scheduler -> svc : collectData() (15분 주기 트리거)
activate svc

svc -> config : 수집 설정 조회 (타임아웃, 임계값)
activate config
config --> svc : {timeout_ms: 2000, 수집 주기 설정}
deactivate config

svc -> repo : 모니터링 대상 목록 조회\n(방문 예정 시간 2시간 전 대상)
activate repo
repo -> db : monitoring_targets 조회\n(visit_datetime BETWEEN now AND now+2h)
db --> repo : 대상 목록
deactivate repo

loop 각 모니터링 대상 장소
    == 외부 API 병렬 3종 호출 (타임아웃 2초) ==
    svc ->> gplaces : 영업 상태 조회 (비동기, Circuit Breaker)
    activate gplaces
    svc ->> weather : 날씨 데이터 조회 (비동기, Circuit Breaker)
    activate weather
    svc ->> gdirections : 이동시간 조회 (비동기, Circuit Breaker)
    activate gdirections

    alt 정상 응답
        gplaces -->> svc : {business_status, current_popularity}
        deactivate gplaces
        weather -->> svc : {precipitation_prob, weather_condition}
        deactivate weather
        gdirections -->> svc : {travel_time_minutes}
        deactivate gdirections

    else 일부 API 실패 (P20 부분 실패 처리)
        gplaces -->> svc : 정상
        deactivate gplaces
        weather -->> svc : 타임아웃
        deactivate weather
        gdirections -->> svc : 정상
        deactivate gdirections

        svc -> cache : 날씨 캐시 조회 (Fallback)
        activate cache
        cache --> svc : 마지막 캐시값\n{is_cached: true, source_status: FALLBACK}
        deactivate cache

    else 전체 실패 (3회 연속)
        svc -> svc : 연속 실패 횟수 증가
        note right of svc : 3회 연속 실패 시 회색 상태 전환
    end

    svc -> cache : 수집 데이터 캐시 저장
    activate cache
    cache --> svc : 저장 완료
    deactivate cache

    == 상태 판정 ==
    svc -> svc : 4단계 상태 판정\n(임계값: config 기준)
    note right of svc
        초록: 모든 항목 정상
        노랑: 1개 이상 주의
        빨강: 1개 이상 위험
        회색: 3회 연속 실패
    end note

    svc -> repo : 상태 이력 저장 (append-only)
    activate repo
    repo -> db : status_history 삽입\n(place_id, status, reason, confidence_score=NULL)
    db --> repo : 저장 완료
    deactivate repo

    svc -> repo : 현재 상태 갱신
    activate repo
    repo -> db : status_current 갱신
    db --> repo : 갱신 완료
    deactivate repo

    alt 상태 변경 감지 (악화 방향)
        svc ->> bus : PlaceStatusChanged 이벤트 발행\n{place_id, prev_status, new_status} (비동기)
    end
end

deactivate svc

@enduml
