@startuml
!theme mono

title BRIF 서비스 - 브리핑 조회

participant "BriefController" as ctrl
participant "BriefingService" as svc
participant "BriefingRepository" as repo
database "PostgreSQL(E)" as db

-> ctrl : GET /api/v1/briefings/{briefing_id}
activate ctrl

ctrl -> ctrl : 브리핑 소유권 검증 (JWT user_id)

ctrl -> svc : getBriefing(briefing_id, user_id)
activate svc

svc -> repo : 브리핑 상세 조회
activate repo
repo -> db : briefings 조회 (briefing_id, user_id)
db --> repo : 브리핑 상세 데이터
deactivate repo

svc -> svc : 브리핑 만료 여부 확인
note right of svc
    생성 시각이 방문 예정 시간 이후이면
    "만료된 브리핑"으로 마킹
end note

alt 만료된 브리핑 (생성 시각 > 방문 예정 시간)
    svc --> ctrl : {briefing, expired: true, message: "이미 지난 브리핑입니다"}
else 유효한 브리핑
    svc --> ctrl : {briefing, expired: false}
end

svc -> repo : 열람 이벤트 기록 (분석 데이터)
activate repo
repo -> db : briefing_logs 갱신\n(read_at, read_latency_seconds)
db --> repo : 완료
deactivate repo

deactivate svc

ctrl --> : 200 OK\n{briefing_id, type, content:\n{business_status, congestion, weather, travel_time, summary},\nalternative_link(주의/위험 시), expired}
deactivate ctrl

@enduml
