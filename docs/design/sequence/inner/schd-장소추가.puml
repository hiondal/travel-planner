@startuml
!theme mono

title SCHD 서비스 - 장소 추가

participant "SchdController" as ctrl
participant "ScheduleService" as svc
participant "ScheduleItemRepository" as repo
participant "PlaceService(E)" as plce
participant "EventBus(E)" as bus
database "PostgreSQL(E)" as db

-> ctrl : POST /api/v1/trips/{trip_id}/schedule-items\n{place_id, visit_datetime, timezone}
activate ctrl

ctrl -> ctrl : 요청 데이터 검증\n(trip_id 소유권, place_id, 방문 일시)

ctrl -> svc : addScheduleItem(trip_id, request)
activate svc

svc -> plce : 장소 상세 정보 조회 (영업시간 포함)
activate plce
plce --> svc : {place_id, name, business_hours, timezone}
deactivate plce

svc -> svc : 방문 일시 현지 시간(IANA) 변환 및 저장
svc -> svc : 영업시간 범위 검증

alt 영업시간 내
    svc -> repo : 일정 장소 저장
    activate repo
    repo -> db : schedule_items 테이블 삽입\n(trip_id, place_id, visit_datetime, timezone, status=ACTIVE)
    db --> repo : 생성된 schedule_item_id
    deactivate repo

    svc ->> bus : ScheduleItemAdded 이벤트 발행\n{schedule_item_id, place_id, visit_datetime} (비동기)

    svc --> ctrl : {schedule_item_id, place_id, visit_datetime, warning: null}

else 영업시간 외
    svc --> ctrl : {warning: "영업시간 외 (HH:mm~HH:mm)", requires_confirmation: true}
    ctrl --> : 200 OK with warning

    note right of ctrl : force=true 파라미터로 재요청 시
    -> ctrl : POST ... {force: true}
    ctrl -> svc : addScheduleItem(... force=true)
    activate svc
    svc -> repo : 일정 장소 저장 (영업시간 외 마킹)
    activate repo
    repo -> db : schedule_items 삽입\n(outside_business_hours=true)
    db --> repo : schedule_item_id
    deactivate repo
    svc ->> bus : ScheduleItemAdded 이벤트 발행 (비동기)
    svc --> ctrl : {schedule_item_id, outside_business_hours: true}
    deactivate svc
end

deactivate svc
ctrl --> : 201 Created
deactivate ctrl

@enduml
