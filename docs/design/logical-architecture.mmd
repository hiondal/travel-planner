graph TB
    %% travel-planner 논리 아키텍처 - Context Map
    %% 작성자: 아키 (소프트웨어 아키텍트) | 2026-02-23

    %% ── Client Layer ──────────────────────────────────────────
    subgraph CL["Client Layer"]
        APP["모바일 클라이언트<br/>(여행자 앱)"]
    end

    %% ── Gateway Layer ─────────────────────────────────────────
    subgraph GWL["Gateway Layer"]
        GW["API Gateway<br/>Azure APIM<br/>─────────────────<br/>Gateway Routing<br/>Gateway Offloading<br/>JWT 검증 · 로깅<br/>Rate Limiting"]
    end

    %% ── Service Layer ─────────────────────────────────────────
    subgraph SVL["Service Layer  (MVP: 모놀리스 배포)"]
        AUTH["AUTH<br/>─────────────<br/>Federated Identity<br/>Google/Apple OAuth<br/>JWT 발급"]
        SCHD["SCHD<br/>─────────────<br/>여행 일정 CRUD<br/>장소 추가/교체<br/>Publisher(이벤트 발행)"]
        PLCE["PLCE<br/>─────────────<br/>장소 검색<br/>Cache-Aside<br/>Circuit Breaker · Retry"]
        MNTR["MNTR<br/>─────────────<br/>15분 주기 수집<br/>4단계 상태 판정<br/>Cache-Aside<br/>Circuit Breaker · Retry<br/>Publisher · Subscriber<br/>Ext. Config Store"]
        BRIF["BRIF<br/>─────────────<br/>브리핑 자동 생성<br/>FCM Push 발송<br/>Circuit Breaker · Retry<br/>Subscriber<br/>BriefingTextGenerator"]
        ALTN["ALTN<br/>─────────────<br/>대안 카드 3장 생성<br/>Cache-Aside<br/>Circuit Breaker<br/>일정 교체 중개"]
        PAY["PAY<br/>─────────────<br/>구독 결제<br/>Circuit Breaker · Retry"]
    end

    %% ── Event Bus ─────────────────────────────────────────────
    subgraph EBL["Event Bus Layer"]
        BUS["Event Bus<br/>─────────────<br/>MVP: 인메모리<br/>Phase 2: Azure Service Bus"]
    end

    %% ── Data Layer ────────────────────────────────────────────
    subgraph DL["Data Layer"]
        DB[("PostgreSQL<br/>서비스별 논리 스키마<br/>단일 인스턴스 MVP")]
        CACHE[("Redis Cache<br/>장소 상태 · 배지<br/>대안 카드 · 세션")]
        CONFIG["Azure App Config<br/>MNTR 임계값<br/>수집 주기 · 타임아웃"]
    end

    %% ── AI Layer (Phase 2 도입 예정) ──────────────────────────
    subgraph AIL["AI Layer  (Phase 2 도입 예정)"]
        AI["AI Pipeline<br/>─────────────<br/>LLM 총평 생성<br/>Azure OpenAI<br/>BriefingTextGenerator<br/>LLMGenerator"]
    end

    %% ── External APIs ─────────────────────────────────────────
    subgraph EXT["External APIs"]
        OAUTH["Google/Apple<br/>OAuth"]
        GPLACES["Google<br/>Places API"]
        WEATHER["OpenWeatherMap<br/>API"]
        GDIREC["Google<br/>Directions API"]
        FCM["FCM<br/>Push 알림"]
        PAYMENT["결제<br/>게이트웨이"]
    end

    %% ── 연결: Client → Gateway (단일 연결선) ──────────────────
    APP -->|"HTTPS"| GW

    %% ── 연결: Gateway → Services (동기) ──────────────────────
    GW -->|"인증/토큰"| AUTH
    GW -->|"일정 관리"| SCHD
    GW -->|"장소 검색"| PLCE
    GW -->|"배지 조회"| MNTR
    GW -->|"브리핑 조회"| BRIF
    GW -->|"대안 카드"| ALTN
    GW -->|"결제"| PAY

    %% ── 연결: 서비스 간 동기 통신 ────────────────────────────
    SCHD -->|"장소 검색 요청"| PLCE
    ALTN -->|"주변 장소 검색"| PLCE
    ALTN -->|"일정 교체 중개"| SCHD
    BRIF -->|"캐시 상태 조회<br/>(재호출 금지)"| MNTR

    %% ── 연결: 비동기 이벤트 (점선) ───────────────────────────
    SCHD -.->|"ScheduleItemAdded<br/>ScheduleItemReplaced<br/>ScheduleItemRemoved"| BUS
    MNTR -.->|"PlaceStatusChanged"| BUS
    BUS -.->|"ScheduleItem 이벤트 구독"| MNTR
    BUS -.->|"PlaceStatusChanged 구독"| BRIF

    %% ── 연결: Cache-Aside (점선) ──────────────────────────────
    PLCE -.->|"Cache-Aside (5분 TTL)"| CACHE
    MNTR -.->|"Cache-Aside (10분 TTL)<br/>배지 무효화"| CACHE
    ALTN -.->|"Cache-Aside (5분 TTL)"| CACHE
    AUTH -.->|"세션 캐시 (30분)"| CACHE

    %% ── 연결: DB (점선) ───────────────────────────────────────
    AUTH -.->|"users · consent"| DB
    SCHD -.->|"trips · schedule_items"| DB
    PLCE -.->|"places"| DB
    MNTR -.->|"status_history"| DB
    BRIF -.->|"briefings"| DB
    ALTN -.->|"selection_logs"| DB
    PAY -.->|"subscriptions"| DB

    %% ── 연결: External Config ─────────────────────────────────
    MNTR -->|"임계값 동적 로드"| CONFIG

    %% ── 연결: External APIs ───────────────────────────────────
    AUTH -->|"OAuth 위임"| OAUTH
    PLCE -->|"CB+Retry"| GPLACES
    MNTR -->|"CB+Retry (병렬)"| GPLACES
    MNTR -->|"CB+Retry (병렬)"| WEATHER
    MNTR -->|"CB+Retry (병렬)"| GDIREC
    BRIF -->|"CB+Retry<br/>Fallback: 인앱 알림"| FCM
    PAY -->|"CB+Retry"| PAYMENT

    %% ── 연결: AI Pipeline Phase 2 (점선) ──────────────────────
    BRIF -.->|"Phase 2: LLMGenerator 교체"| AI
    AI -.->|"Phase 2: Azure OpenAI 호출"| AIOPENAI["Azure OpenAI<br/>(Phase 2)"]

    %% ── 스타일 정의 ───────────────────────────────────────────
    classDef clientStyle fill:#BFDBFE,stroke:#3B82F6,stroke-width:2px
    classDef gatewayStyle fill:#1D4ED8,stroke:#1E3A8A,stroke-width:2px,color:#fff
    classDef authStyle fill:#4ECDC4,stroke:#0F766E,stroke-width:2px
    classDef schdStyle fill:#F59E0B,stroke:#B45309,stroke-width:2px
    classDef plceStyle fill:#8B5CF6,stroke:#6D28D9,stroke-width:2px,color:#fff
    classDef mntrStyle fill:#EF4444,stroke:#B91C1C,stroke-width:2px,color:#fff
    classDef brifStyle fill:#10B981,stroke:#047857,stroke-width:2px,color:#fff
    classDef altnStyle fill:#F97316,stroke:#C2410C,stroke-width:2px,color:#fff
    classDef payStyle fill:#6366F1,stroke:#4338CA,stroke-width:2px,color:#fff
    classDef busStyle fill:#EC4899,stroke:#BE185D,stroke-width:2px,color:#fff
    classDef dbStyle fill:#FEF3C7,stroke:#D97706,stroke-width:2px
    classDef cacheStyle fill:#FDE68A,stroke:#F59E0B,stroke-width:2px
    classDef configStyle fill:#E0E7FF,stroke:#6366F1,stroke-width:2px
    classDef aiStyle fill:#D1FAE5,stroke:#10B981,stroke-width:2px,stroke-dasharray:6 3
    classDef externalStyle fill:#F3F4F6,stroke:#9CA3AF,stroke-width:2px

    class APP clientStyle
    class GW gatewayStyle
    class AUTH authStyle
    class SCHD schdStyle
    class PLCE plceStyle
    class MNTR mntrStyle
    class BRIF brifStyle
    class ALTN altnStyle
    class PAY payStyle
    class BUS busStyle
    class DB dbStyle
    class CACHE cacheStyle
    class CONFIG configStyle
    class AI,AIOPENAI aiStyle
    class OAUTH,GPLACES,WEATHER,GDIREC,FCM,PAYMENT externalStyle
